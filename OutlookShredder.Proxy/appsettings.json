{
  "Logging": {
    "LogLevel": {
      // Default verbosity for all components
      "Default": "Information",
      // Suppress routine ASP.NET Core request pipeline noise
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Kestrel listen addresses — change port here if something else is already using 7000.
  // Bound to 127.0.0.1 (loopback only) — the proxy must never be reachable off the machine.
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://127.0.0.1:7000" }
    },
    "Limits": {
      // Cap concurrent connections to blunt a local connection flood (WS2).
      "MaxConcurrentConnections": 100,
      "MaxConcurrentUpgradedConnections": 20
    }
  },

  // ── WS1 secrets → Azure Key Vault ────────────────────────────────────────────
  // The proxy fetches secrets (Anthropic--ApiKey, Google--ApiKey, SharePoint--TenantId/ClientId/
  // ClientSecret, ServiceBus--ConnectionString) from this vault at startup using the SIGNED-IN USER's
  // Entra token (Windows WAM broker, silent — no prompt, no cert). Vault values override the local
  // appsettings.secrets.json; if the vault is unreachable the proxy falls back to the file (and logs
  // "[Secrets] source=file"). Leave Uri blank to disable Key Vault and use the file only.
  //   Uri:      the vault URL, e.g. "https://forge-secrets.vault.azure.net/"  (non-secret)
  //   Enabled:  set false to skip Key Vault entirely (file-only)
  //   TenantId: optional — pin the broker to a tenant; omit to use the signed-in account's tenant
  "KeyVault": {
    "Uri": "https://forge-secrets-msh.vault.azure.net/",
    "Enabled": true,
    "TenantId": "9826771f-a143-4d02-b286-cdd0c4c17ee6"
  },

  // ── AI provider selection ────────────────────────────────────────────────────
  // Set Provider to "claude" or "gemini" (case-insensitive).
  // Override in appsettings.secrets.json to switch without touching this file.
  "AI": {
    "Provider": "roundrobin"
  },

  // Anthropic API key — leave blank here and set in appsettings.secrets.json
  "Anthropic": {
    "ApiKey": ""
  },

  // Google Gemini API key — leave blank here and set in appsettings.secrets.json
  "Google": {
    "ApiKey": ""
  },

  // Gemini API behaviour (mirrors Claude section — used when AI:Provider = "gemini")
  "Gemini": {
    // Gemini model ID (see https://ai.google.dev/gemini-api/docs/models)
    "Model": "gemini-2.5-flash",
    // Retry attempts before giving up
    "MaxRetries": 3,
    // Characters of email body / attachment text sent to Gemini (truncated beyond this)
    "MaxContentChars": 12000,
    // Characters of body context included alongside an attachment extraction
    "MaxContextChars": 2000
  },

  // Claude API behaviour
  "Claude": {
    // Anthropic model ID to use for extraction (e.g. claude-sonnet-4-6, claude-haiku-4-5-20251001)
    "Model": "claude-sonnet-4-6",
    // Maximum tokens Claude may return per extraction call.
    // A warning is logged if this limit is hit — raise it if truncation warnings appear.
    "MaxTokens": 4096,
    // How many times to retry a failed Claude API call (429 / 5xx / network errors).
    // Delays are randomised: ~2-4s, ~5-10s, ~15-25s between successive attempts.
    "MaxRetries": 3,
    // Seconds before an in-flight Claude API call is abandoned
    "TimeoutSeconds": 60,
    // Characters of email body / attachment text sent to Claude (truncated beyond this)
    "MaxContentChars": 12000,
    // Characters of body context included alongside an attachment extraction
    "MaxContextChars": 2000
  },

  // SMS customer-inquiry AI drafts. SystemPrompt + ShopServices default to the baked-in copy in
  // InquiryDraftPrompt (DefaultSystemPrompt / DefaultShopServices). Set either here (or in
  // appsettings.secrets.json / Key Vault) to override at runtime WITHOUT a deploy — e.g. edit ShopServices as
  // shop capabilities change (deburr/polish timesaver, lathes, mills, tube lasers, water jets, …).
  "InquiryDraft": {
    "SystemPrompt": "",
    "ShopServices": ""
  },

  // Two-pass bill extraction: after the text classifier routes an email into a financial leaf
  // (Supplier/Invoices and Bills, Receipts, Statements) and it has a PDF, a second targeted AI pass
  // reads the PDF to fill the amount + supplier reference + our PO# for bill -> PO matching.
  "BillExtraction": {
    // Set false to disable the second PDF pass entirely (text-only classification still runs).
    "Enabled": true,
    // Model for the PDF pass; falls back to Claude:ErpModel then claude-haiku-4-5 when unset.
    "ClaudeModel": "claude-haiku-4-5-20251001"
  },

  // Two-pass order-confirmation extraction: after the text classifier routes an email into
  // Supplier/Order Confirmations and it has a PDF, a second targeted AI pass reads the PDF SOC to fill
  // the promised ship/delivery (ETA) date -> the PO ExpectedDate that schedules the waiting card.
  "ConfirmationExtraction": {
    // Set false to disable the confirmation PDF pass (text-only classification still runs).
    "Enabled": true,
    // Model for the PDF pass; falls back to Claude:ErpModel then claude-haiku-4-5 when unset.
    "ClaudeModel": "claude-haiku-4-5-20251001"
  },

  // SharePoint / Microsoft Graph
  "SharePoint": {
    // Full URL of the SharePoint site that owns the RFQ list
    "SiteUrl": "https://metalsupermarkets-my.sharepoint.com/personal/angus_mithrilmetals_com",
    // Display name of the SharePoint list to write rows into
    "ListName": "RFQ Line Items",
    // Azure AD app registration credentials — set in appsettings.secrets.json
    "TenantId":     "",
    "ClientId":     "",
    "ClientSecret": "",
    // Characters of the email body stored in the EmailBody column (very long bodies are truncated)
    "MaxEmailBodyChars": 10000,
    // How many existing SP rows are fetched when checking for duplicates before inserting
    "MaxSearchItems": 500
  },

  // Mail poller behaviour
  "Mail": {
    // UPN / email address of the mailbox to monitor. The store mailbox is non-sensitive (it is the same
    // address as FromAddress below) and lives here — NOT in appsettings.secrets.json — so it survives the
    // WS1 Key-Vault secrets wipe. A per-machine override may go in appsettings.local.json.
    "MailboxAddress": "store@mithrilmetals.com",
    // Address that RFQ emails are sent FROM (must be a mailbox on the same tenant)
    "FromAddress": "store@mithrilmetals.com",
    // How often (seconds) the poller checks for new unprocessed messages
    "PollIntervalSeconds": 30,
    // Rolling window (hours) of past messages to consider each poll cycle
    "LookbackHours": 24,
    // Maximum AI API calls per minute — governed by your Anthropic/Google tier
    "MaxEmailsPerMinute": 100,
    // Maximum emails processed concurrently (each acquires a rate-limit slot before calling AI)
    "MaxConcurrency": 8,
    // Characters of email body included as context when processing an attachment
    "BodyContextChars": 2000,
    // When false (recommended): body-only emails with no [XXXXXX] job reference skip Claude
    //   and get a direct placeholder row under [000000] — much faster for non-quote mail.
    // When true: every email goes through Claude regardless (original behaviour, slower).
    "ExtractBodyWithoutJobRef": false,
    // Known user-initials prefixes for the bare-token RFQ fallback. When a reply subject carries
    // an RFQ id with no [brackets] and no "RFQ"/"Job Ref" prefix (e.g. "re: RSX9JS revised"), the
    // poller accepts an UPPERCASE token of the form <initials><4 Crockford chars> only if its
    // 2-letter prefix is in this list AND the token is a real RFQ id. Add initials as users grow.
    "RfqInitials": "AW,JM,AC,RS",
    // ALL direct child folders of Inbox are scanned automatically (supplier subfolders
    // created by Outlook rules).  List any folder display-names here to skip them.
    // "Forwards": the mailbox bridge mirrors ALL hackensack@metalsupermarkets.com mail
    //   into Inbox/Forwards via a Forward-as-attachment rule; that folder gets its own
    //   bridge actions, NOT RFQ extraction, so it is excluded from the poller scan.
    "ExcludeFolders": [ "Forwards" ]
  },

  // Product Catalog — sourced from a SharePoint list on the personal OneDrive site
  "ProductCatalog": {
    // Full URL of the SharePoint personal/OneDrive site that owns the catalog list
    "SiteUrl": "https://metalsupermarkets-my.sharepoint.com/personal/angus_mithrilmetals_com",
    // Display name of the list; must have a Title column and optionally a SearchKey column
    "ListName": "Product Catalog"
  },

  // QC list — SharePoint personal site that hosts the QC list
  "QC": {
    "SiteUrl": "https://metalsupermarkets-my.sharepoint.com/personal/angus_mithrilmetals_com",
    // Rolling window of quotes used to compute LQ (average $/lb)
    "LqShortDays": 7,
    "LqLongDays": 14,
    // How often (minutes) each proxy instance recomputes LQ in the background.
    // All instances compute the same average so concurrent writes are idempotent.
    // Random jitter (up to half the interval) is added at startup to stagger instances.
    "LqUpdateIntervalMinutes": 60,
    // Analytics (Sharp Price / Suggested QC columns in the QC tab)
    "AnalyticsPrimaryDays":   7,     // recency-weighted window
    "AnalyticsFallbackDays":  60,    // extended lookback when primary data is thin
    "AnalyticsRecentDays":    2,     // quotes within this age get AnalyticsRecentWeight
    "AnalyticsRecentWeight":  3.0,   // multiplier for very recent quotes
    "AnalyticsThinThreshold": 2,     // fewer than this many quotes triggers metal-category fallback
    "AnalyticsOutlierRatio":  3.0,   // iteratively reject tokens outside [median/ratio, median*ratio]
    "AnalyticsOutlierMinTokens": 4   // only start outlier filter when group has >= this many tokens
  },

  // Pre-insert product deduplication
  // When DryRun is true: duplicates are logged but all rows are still written to SP.
  // Set to false once you have reviewed the [Dedup DRY] log output and are satisfied.
  "Dedup": {
    "DryRun": true
  },

  // Proxy CORS — must match the URL the dashboard / add-in host is served from
  "Proxy": {
    "AllowedOrigin": "https://localhost:3000",

    // ── WS2 local REST auth ──────────────────────────────────────────────────
    // AuthEnforce=true: hard-enforce — non-exempt /api requests without a valid token+HMAC get 401
    //   (429 over the rate cap). Endpoints used by the Chrome extension / Office add-in are exempt
    //   (see ProxyAuthService.Exempt) and always served. Set false to fall back to warn-only (logs
    //   "[Auth] would-reject …" but still serves) if a legitimate caller is unexpectedly rejected.
    "AuthEnforce": true,
    // Accepted clock skew (seconds) between the signed timestamp and the proxy clock; also bounds the
    // nonce replay window.
    "AuthSkewSeconds": 30,
    // Per-second cap on non-exempt /api requests.
    "RateLimitPerSecond": 300
  },

  // Background job that auto-completes stale RFQ References. Runs in the proxy
  // process on a configurable cadence and appends "[auto-completed after Nd]" to
  // Notes on each RFQ it marks Complete. Results are logged to proxy-YYYYMMDD.log.
  "RfqAutoComplete": {
    // Disable to suppress the job entirely (e.g. while debugging).
    "Enabled": true,
    // Cycle cadence. Fractional hours accepted.
    "IntervalHours": 1,
    // RFQs older than this (based on DateCreated, falling back to the item's
    // SharePoint Created timestamp) become eligible for auto-completion.
    "DaysThreshold": 7
  },

  // Publish folder on SharePoint — used by Shredder clients to check for updates
  // and download the install package without needing OneDrive synced locally.
  // SiteUrl: the SharePoint team site that contains the Documents library.
  // FolderPath: path within the default drive (Documents library), e.g. "publish/current".
  "Publish": {
    "SiteUrl": "https://metalsupermarkets.sharepoint.com/sites/Hackensack",
    "FolderPath": "publish/current"
  },

  // Forge scheduled task infrastructure — Azure Service Bus queue for competing-consumer task dispatch.
  // TaskQueueName: the queue that carries scheduled task messages (one per task per day, dedup'd).
  // Configured here with defaults; ServiceBus:ConnectionString is set in appsettings.secrets.json.
  "ForgeScheduler": {
    "TaskQueueName": "forge-task-scheduler"
  },

  // ERP file watcher — watches a local folder for PDF files generated by the ERP system.
  // Each new PDF is classified by Claude; confirmed ERP documents are written to the
  // ErpDocuments SharePoint list with the PDF attached. Duplicates (same document number
  // from multiple proxies) have the older record marked IsArchived=true.
  "FileWatcher": {
    // Set to "false" to disable the watcher entirely (e.g. on non-store machines).
    "Enabled": "true",
    // Folder to watch. Defaults to %USERPROFILE%\Downloads if omitted.
    "WatchPath": ""
  },

  // Mailbox bridge — read-only mail viewer over a "Forward as attachment" mirror folder
  // (see wip/mailbox-bridge.md). A server-side Exchange rule on a mailbox we cannot
  // authenticate into (hackensack@metalsupermarkets.com) forwards every message as a
  // .eml attachment into a folder on a mailbox we own (store@mithril → Inbox/Forwards).
  // The bridge polls that folder, parses the embedded original, and serves /api/mailbox/*.
  // The watched/destination addresses are internal (already referenced above), not secrets, so the
  // proven prod entry is committed here for durability — it survives reinstall AND the Key-Vault secrets
  // wipe (which is why it must NOT live in appsettings.secrets.json). A per-machine override may still go
  // in appsettings.local.json (loaded after this, wins). Empty Mailboxes ⇒ bridge idle.
  // NOTE: a non-empty entry also enables MailAutoCaptureService (MailWorkbench:AutoCapture, default on),
  // which auto-classifies the mirrored mail into the Inbox workbench. Set AutoCapture=false for read-only.
  "MailboxBridge": {
    "PollIntervalSeconds": 10,
    "Mailboxes": [
      {
        "WatchedUpn":            "hackensack@metalsupermarkets.com",
        "DisplayName":           "Hackensack",
        "DestinationUpn":        "store@mithrilmetals.com",
        "DestinationFolderPath": "Inbox/Forwards",
        "OutboundFolderPath":    "Inbox/Forwards",
        "RelaySenderUpn":        "store@mithrilmetals.com",
        "EnvelopeSubjectPrefix": "[SHR-SEND]"
      }
    ]
  },

  // SignalWire SMS integration. ApiToken is a real secret → Key Vault as 'silmaril-sms-channel'
  // (mapped to SignalWire:ApiToken at startup by SecretsBootstrap). The non-secret bits below are
  // committed here so they ship to every proxy host (the "bake into install" answer for outbound).
  // SpaceUrl: your-space.signalwire.com (no https://)  ·  FromNumber: E.164 (e.g. "+19731234567")
  "SignalWire": {
    "SpaceUrl":    "mithril-metals-corp.signalwire.com",
    "ProjectId":   "89165ee2-29c5-4aad-88d1-04bce46264f1",
    "ApiToken":    "",
    "FromNumber":  "+15513779357",
    // Public base URL SignalWire calls (now the Azure Function ingress), used to reconstruct the exact
    // URL the inbound/status webhook signature was computed over. Also the base for outbound statusCallback.
    "WebhookBaseUrl": "https://shredder-sms-webhook.azurewebsites.net",
    // Optional dedicated signing key; defaults to ApiToken (Twilio-compatible scheme).
    "SigningKey": "",
    // Local-dev only: accept unsigned webhooks when no token is configured. MUST stay false in prod.
    "AllowUnsignedWebhooks": false,
    // Carrier-compliance confirmations (STOP/START/HELP). AppHelpReply=true → the APP sends them (current
    // owner, since SignalWire's 10DLC campaign templates aren't registered yet). When that campaign is
    // registered to auto-send + enforce opt-out at the network level, set AppHelpReply=false to hand it back
    // and avoid double-texting. The *Reply keys override the built-in default copy (blank = use default).
    "AppHelpReply": true,
    "HelpReply":   "",
    "OptOutReply": "",
    "OptInReply":  ""
  },

  // Internal messaging — list of usernames that can receive internal messages
  // Add each Shredder user's UserPreferences.UserName value here
  "Messaging": {
    "KnownUsers": [ "Angus", "Singh", "Ashlee", "Jay M." ]
  },

  // Customer / Contact import directory — drop CSV files here and call POST /api/import/run.
  // Leave blank to use the default: %LOCALAPPDATA%\Shredder\Import\
  // Processed files are moved to Import\processed\{timestamp}_{filename} after each run.
  "Import": {
    "Directory": ""
  },

  // ERP terms-and-conditions footer - stamps a configurable disclaimer as a small footnote
  // (solid white box that blocks the existing page-bottom boilerplate) on outbound ERP docs.
  // Applied in FileWatcherService after detection, gated to DocumentTypes. Geometry is in PDF
  // points (72 = 1 inch). Tune the look live via POST /api/erp/footer-preview before shipping.
  "ErpFooter": {
    "Enabled": true,
    "Text": "All sales final on cut and special-order material. Full length material return by authorization only — 30–50% restocking fee, subject to inspection. Claims within 15 days of receipt.",
    "DocumentTypes": [ "SalesOrder", "Quotation" ],
    "FontSizePt": 7.0,
    "SideMarginPt": 36.0,
    "BottomMarginPt": 14.0,
    "BoxHeightPt": 30.0,
    "EveryPage": true,
    "TopRule": true,
    "Center": true
  },
  // Trigger workflow — auto-add behaviour for newly arrived PickingSlips.
  // ProcessingKeywords: substring (case-insensitive) matches against B: shop-comment lines.
  // When at least one keyword matches, a Processing workflow card is auto-created in the
  // Prioritize column (AssignedDate=""). The Delivery card is auto-created when the slip's
  // "Delivery Method:" header is literally "Delivery" (other methods do not auto-add).
  "Workflow": {
    "ProcessingKeywords": [ "Laser Cutting", "Bending", "Welding", "Drilling", "Fabricating" ],
    // Worklist/Delivery/Transfer board read window: dated cards are loaded only if their AssignedDate
    // is within this many business days back (or in the future); undated Prioritize-intake cards always
    // load. Keeps each proxy's card cache bounded as the WorkflowCards list grows. The read itself is
    // fully paginated, so newly-added cards are never silently dropped regardless of this value.
    "ReadWindowBusinessDays": 5
  },

  // PO confirmation monitor (Fulfillment loop - wip/fulfillment-loop.md). Two clocks per PO.
  // Supplier-acknowledgment: green under AckAmberMinutes, amber, then red after AckRedMinutes
  //   OR once the EST wall-clock passes AckRedCutoffEst (supplier cutoff - won't ship today).
  // Pay-to-release (our action, tighter): amber after PayAmberMinutes, red after PayRedMinutes
  //   OR past PayRedCutoffEst. Minutes are integers; cutoffs are HH:mm Eastern.
  "PoMonitor": {
    "AckAmberMinutes": 60,
    "AckRedMinutes":   120,
    "AckRedCutoffEst": "15:30",
    "MonitorWindowBusinessDays": 3,
    "PayAmberMinutes": 30,
    "PayRedMinutes":   45,
    "PayRedCutoffEst": "15:15"
  },

  // PO confirmation accelerator (Fulfillment loop) - matches classified supplier
  // Order-Confirmation / Receipt emails to open POs by HSK-PO number and records the confirmation.
  // Auto=true: auto-confirm (via=email/payment), reversible. false: log suggestions only.
  // Stale POs (beyond PoMonitor:MonitorWindowBusinessDays) are skipped - backlog stays stale.
  "PoMatcher": {
    "Enabled": true,
    "Auto": true,
    "IntervalMinutes": 10,
    "ConfidenceFloor": 0.0
  },

  // Bill -> PO matcher (Fulfillment loop) - matches a classified payment-processor bill
  // (Supplier/Invoices and Bills) to the open PO it pays for and flips it to PaymentStatus=Required.
  // Multi-signal: our PO# on the bill, then supplierReference==SLI QuoteReference, then exact amount.
  // Auto=false (suggest-first): only proposes matches (logged + via match-bills?apply=false). Set
  // Auto=true (or call match-bills?apply=true) to write PaymentStatus=Required + the bill pointer.
  "BillMatcher": {
    "Enabled": true,
    "Auto": true,
    "IntervalMinutes": 15,
    "AmountTolerance": 0.01
  },

  // Persistent disk cache — survives reinstall at %LOCALAPPDATA%\ShredderData\Cache\
  "PersistentCache": {
    // Days after which a full SP refresh is triggered on proxy startup
    "FullRefreshIntervalDays": 7,
    // Minutes subtracted from lastDeltaUtc when fetching new items (overlap buffer)
    "DeltaBufferMinutes": 10,
    // Set false to disable all background cache refreshes (still serves from disk)
    "Enabled": true,
    // Maximum age of completed RFQ data kept in the archive cache (refs + RLI).
    // Refs older than this are pruned on full rebuild and on warm-from-disk.
    "ArchiveCacheMaxDays": 60
  },

  // Phone call log — rolling window returned by GET /api/phone/call-log
  "Phone": {
    // Hours of history to return (e.g. 36 = last 36 hours, crosses midnight boundaries)
    "LookbackHours": 36
  },

  // Zoom Phone call watcher — detects incoming Zoom Phone popups via WinEvent hook.
  // WatcherEnabled: set false to disable entirely (e.g. on machines without Zoom Phone).
  // DebugAllWindows: set true to log every window opened by Zoom.exe — use when calls
  //   are not being detected to find the real window class name.
  // DedupWindowSeconds: skip a call-log write when the same caller phone was already
  //   logged within this many seconds (collapses dupes from multiple proxy sources).
  "Zoom": {
    "WatcherEnabled": true,
    "DebugAllWindows": false,
    "DedupWindowSeconds": 5
  }
}
